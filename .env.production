# ═══════════════════════════════════════════════
# MUDRO Production Environment
# Copy to /etc/mudro/.env and fill real values
# ═══════════════════════════════════════════════

# ── Core DB ──
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DSN=postgres://mudro_app:CHANGE_ME@db:5432/gallery?sslmode=disable

# ── JWT ──
JWT_SECRET=CHANGE_ME_32_CHARS_RANDOM_SECRET
MUDRO_ENV=production

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=GET_FROM_BOTFATHER
TELEGRAM_ALLOWED_USERNAME=
REPORT_BOT_TOKEN=
REPORT_CHAT_ID=
REPORT_INTERVAL_MIN=30

# ── Casino DB ──
CASINO_POSTGRES_PASSWORD=CHANGE_ME_CASINO_DB_PASSWORD
CASINO_DSN=postgres://postgres:CHANGE_ME_CASINO_DB_PASSWORD@casino-db:5432/mudro_casino?sslmode=disable
CASINO_MAIN_DSN=postgres://mudro_app:CHANGE_ME@db:5432/gallery?sslmode=disable

# ── Casino Service ──
CASINO_SERVICE_URL=http://casino-api:8081
CASINO_INTERNAL_SECRET=CHANGE_ME_RANDOM_INTERNAL_SECRET
CASINO_START_BALANCE=500
CASINO_RTP_BPS=9500
CASINO_MAX_BET=1000
CASINO_BONUS_FREE_SPINS=10
CASINO_FAUCET_AMOUNT=1000
CASINO_BONUS_TELEGRAM_BOT_TOKEN=GET_FROM_BOTFATHER
CASINO_BONUS_TELEGRAM_CHANNEL=
CASINO_ROULETTE_BETTING_MS=15000
CASINO_ROULETTE_LOCK_MS=1500
CASINO_ROULETTE_SPIN_MS=4500
CASINO_ROULETTE_RESULT_MS=3500

# ── API ──
API_ADDR=:8080
API_ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
API_RATE_LIMIT_RPS=20
API_RATE_LIMIT_BURST=40

# ── Redis ──
REDIS_RATE_LIMIT_ENABLED=true
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Kafka (optional) ──
KAFKA_ENABLED=false
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_TASKS=mudro.agent.tasks.v1

# ── MinIO ──
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO

# ── LLM / OpenRouter ──
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
OPENROUTER_MODEL=openai/gpt-4.1-mini

# ── Frontend (build-time) ──
VITE_API_BASE_URL=/api

# ── Domains ──
DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com
