# ─────────────────────────────────────────────
# Mudro Environment Configuration
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ── Core Database ──
DSN=postgres://mudro_app:CHANGE_ME@localhost:5433/gallery?sslmode=disable
POSTGRES_PASSWORD=CHANGE_ME

# ── Auth / JWT ──
JWT_SECRET=CHANGE_ME_min_16_chars_long_secret
MUDRO_ENV=development

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERNAME=
REPORT_BOT_TOKEN=
REPORT_CHAT_ID=
REPORT_INTERVAL_MIN=30

# ── Casino ──
CASINO_BOT_TOKEN=
# For Supabase-backed casino, replace CASINO_DSN with the direct connection string and keep sslmode=require.
CASINO_DSN=postgres://mudro_app:CHANGE_ME@localhost:5434/mudro_casino?sslmode=disable
# Main wallet source for casino projection/reconcile. In local dev it usually matches DSN.
CASINO_MAIN_DSN=postgres://mudro_app:CHANGE_ME@localhost:5433/gallery?sslmode=disable
CASINO_ADMIN_KEY=
CASINO_DEMO_MODE=false
CASINO_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
CASINO_START_BALANCE=500
CASINO_BONUS_FREE_SPINS=10
CASINO_BONUS_TELEGRAM_BOT_TOKEN=
CASINO_BONUS_TELEGRAM_CHANNEL=
CASINO_BONUS_TELEGRAM_API_BASE=https://api.telegram.org
CASINO_FAUCET_AMOUNT=1000
CASINO_ROULETTE_BETTING_MS=15000
CASINO_ROULETTE_LOCK_MS=1500
CASINO_ROULETTE_SPIN_MS=4500
CASINO_ROULETTE_RESULT_MS=3500

# ── API Server ──
API_ADDR=:8080
API_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
API_RATE_LIMIT_RPS=20
API_RATE_LIMIT_BURST=40

# ── Redis (rate limiting) ──
REDIS_RATE_LIMIT_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Kafka (optional, for agent tasks) ──
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_TASKS=mudro.agent.tasks.v1

# ── MinIO (media storage) ──
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME

# ── Services URLs (for gateway/proxy) ──
CASINO_SERVICE_URL=http://localhost:8082
API_BASE_URL=http://localhost:8080

# ── OpenRouter (for bot /mudro command) ──
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
# Legacy aliases supported by code for backwards compatibility:
# OPENAI_API_KEY=
# OPENAI_MODEL=
