[Unit]
Description=MUDRO agent worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mudro
Group=mudro
SupplementaryGroups=docker
WorkingDirectory=/opt/mudro/app
EnvironmentFile=-/etc/mudro/runtime/mudro-agent.env
Environment=HOME=/var/lib/mudro
Environment=XDG_CACHE_HOME=/var/lib/mudro/.cache
Environment=GOCACHE=/var/lib/mudro/go-build
ExecStart=/opt/mudro/bin/mudro-agent --mode worker --interval 15s --worker-id systemd-worker-1
Restart=on-failure
RestartSec=5
UMask=0027
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictNamespaces=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
SystemCallFilter=@system-service
ReadWritePaths=/var/lib/mudro /var/log/mudro /opt/mudro/app/.codex /var/run/docker.sock

[Install]
WantedBy=multi-user.target
