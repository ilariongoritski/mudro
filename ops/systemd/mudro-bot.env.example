# Copy to /etc/mudro/runtime/mudro-bot.env on VPS.
# Keep real values out of git.

MUDRO_ENV=production
MUDRO_ROOT=/opt/mudro/app
DSN=postgres://mudro_app:<APP_PASSWORD>@localhost:5433/gallery?sslmode=disable
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERNAME=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
API_BASE_URL=http://127.0.0.1:8080
TELEGRAM_MESSAGE_LIMIT=3800
