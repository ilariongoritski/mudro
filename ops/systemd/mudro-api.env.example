# Copy to /etc/mudro/runtime/mudro-api.env on VPS.
# Keep real values out of git.

MUDRO_ENV=production
MUDRO_ROOT=/opt/mudro/app
DSN=postgres://mudro_app:<APP_PASSWORD>@localhost:5433/gallery?sslmode=disable
API_ADDR=:8080
JWT_SECRET=change-me
CASINO_SERVICE_URL=http://127.0.0.1:8082
MEDIA_ROOT=/var/lib/mudro/media
API_RATE_LIMIT_RPS=20
API_RATE_LIMIT_BURST=40
REDIS_RATE_LIMIT_ENABLED=false
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
