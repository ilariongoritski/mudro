# Copy to /etc/openclaw/runtime/claudeusageproxy.env on VPS.
# Keep real values out of git.

CLAUDEUSAGEPROXY_BIN=/opt/mudro/bin/claudeusageproxy
MUDRO_CLAUDE_PROXY_ADDR=127.0.0.1:8788
MUDRO_CLAUDE_UPSTREAM_BASE_URL=https://claude-api.filips-site.online
MUDRO_CLAUDE_API_KEY=
MUDRO_CLAUDE_PROXY_TOKEN=
MUDRO_CLAUDE_ACCOUNTING_ROOT=/var/lib/openclaw/claude-orch
MUDRO_CLAUDE_USAGE_LOG=/var/lib/openclaw/claude-orch/ledger/usage_log.jsonl
MUDRO_CLAUDE_TOKEN_USAGE=/var/lib/openclaw/claude-orch/ledger/token_usage.yaml
MUDRO_CLAUDE_ROLE_USAGE=/var/lib/openclaw/claude-orch/ledger/role_usage.yaml
