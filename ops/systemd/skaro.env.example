# Copy to /etc/openclaw/runtime/skaro.env on VPS.
# Keep real values out of git.

SKARO_BIN=/usr/local/bin/skaro
SKARO_PORT=4700
ANTHROPIC_BASE_URL=https://claude-api.filips-site.online
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
MUDRO_CLAUDE_PROXY_URL=http://127.0.0.1:8788
SKARO_LOCAL_ROOT=/var/lib/openclaw/skaro
MUDRO_CLAUDE_ACCOUNTING_ROOT=/var/lib/openclaw/claude-orch
MUDRO_CLAUDE_USAGE_LOG=/var/lib/openclaw/claude-orch/ledger/usage_log.jsonl
MUDRO_CLAUDE_TOKEN_USAGE=/var/lib/openclaw/claude-orch/ledger/token_usage.yaml
MUDRO_CLAUDE_ROLE_USAGE=/var/lib/openclaw/claude-orch/ledger/role_usage.yaml
MUDRO_CLAUDE_RUNS_DIR=/var/lib/openclaw/claude-orch/runs
MUDRO_CLAUDE_STATE_DIR=/var/lib/openclaw/claude-orch/state
TZ=Europe/Moscow
