# Copy to /etc/mudro/runtime/mudro-agent.env on VPS.
# Keep real values out of git.

MUDRO_ENV=production
MUDRO_ROOT=/opt/mudro/app
DSN=postgres://mudro_app:<APP_PASSWORD>@localhost:5433/gallery?sslmode=disable
KAFKA_ENABLED=false
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_CLIENT_ID=mudro-agent
KAFKA_TOPIC_TASKS=mudro.agent.tasks.v1
