{
    "version":  "2.0.0",
    "tasks":  [
                  {
                      "label":  "Skaro: UI",
                      "problemMatcher":  [

                                         ],
                      "command":  "powershell",
                      "type":  "shell",
                      "args":  [
                                   "-ExecutionPolicy",
                                   "Bypass",
                                   "-File",
                                   "${workspaceFolder}\\\\scripts\\\\skaro-local.ps1",
                                   "ui",
                                   "--port",
                                   "4700",
                                   "--no-browser"
                               ],
                      "presentation":  {
                                           "reveal":  "always",
                                           "panel":  "dedicated",
                                           "focus":  false,
                                           "clear":  false
                                       },
                      "isBackground":  true
                  },
                  {
                      "label":  "Skaro: Open Dashboard",
                      "problemMatcher":  [

                                         ],
                      "command":  "powershell",
                      "type":  "shell",
                      "args":  [
                                   "-ExecutionPolicy",
                                   "Bypass",
                                   "-Command",
                                   "Start-Process \u0027http://127.0.0.1:4700/dashboard\u0027"
                               ],
                      "presentation":  {
                                           "panel":  "shared",
                                           "reveal":  "never"
                                       }
                  },
                  {
                      "label":  "Skaro: Stop UI",
                      "problemMatcher":  [

                                         ],
                      "command":  "powershell",
                      "type":  "shell",
                      "args":  [
                                   "-ExecutionPolicy",
                                   "Bypass",
                                   "-Command",
                                   "Get-NetTCPConnection -LocalPort 4700 -State Listen -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique | ForEach-Object { Stop-Process -Id $_.ToString() -Force }"
                               ],
                      "presentation":  {
                                           "reveal":  "always",
                                           "panel":  "shared",
                                           "focus":  false,
                                           "clear":  true
                                       }
                  },
                  {
                      "label":  "Skaro: Status",
                      "problemMatcher":  [

                                         ],
                      "command":  "powershell",
                      "type":  "shell",
                      "args":  [
                                   "-ExecutionPolicy",
                                   "Bypass",
                                   "-File",
                                   "${workspaceFolder}\\\\scripts\\\\skaro-local.ps1",
                                   "status"
                               ],
                      "presentation":  {
                                           "reveal":  "always",
                                           "panel":  "shared",
                                           "focus":  false,
                                           "clear":  true
                                       }
                  },
                  {
                      "label":  "Skaro: Config",
                      "problemMatcher":  [

                                         ],
                      "command":  "powershell",
                      "type":  "shell",
                      "args":  [
                                   "-ExecutionPolicy",
                                   "Bypass",
                                   "-File",
                                   "${workspaceFolder}\\\\scripts\\\\skaro-local.ps1",
                                   "config",
                                   "--show"
                               ],
                      "presentation":  {
                                           "reveal":  "always",
                                           "panel":  "shared",
                                           "focus":  false,
                                           "clear":  true
                                       }
                  }
              ]
}
