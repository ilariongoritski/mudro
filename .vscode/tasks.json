{
  "version": "2.0.0",
  "tasks": [
    {
      "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "focus": false,
        "clear": false
      },
      "label": "Skaro: UI",
      "type": "shell",
      "problemMatcher": [],
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\scripts\\\\skaro-local.ps1",
        "ui",
        "--port",
        "4701",
        "--no-browser"
      ]
    },
    {
      "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "presentation": {
        "panel": "shared",
        "reveal": "never"
      },
      "label": "Skaro: Open Dashboard",
      "type": "shell",
      "problemMatcher": [],
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "Start-Process 'http://127.0.0.1:4701/dashboard'"
      ]
    },
    {
      "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "presentation": {
        "panel": "shared",
        "reveal": "always",
        "focus": false,
        "clear": true
      },
      "label": "Skaro: Stop UI",
      "type": "shell",
      "problemMatcher": [],
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "Get-NetTCPConnection -LocalPort 4701 -State Listen -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique | ForEach-Object { Stop-Process -Id $_.ToString() -Force }"
      ]
    },
    {
      "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "presentation": {
        "panel": "shared",
        "reveal": "always",
        "focus": false,
        "clear": true
      },
      "label": "Skaro: Status",
      "type": "shell",
      "problemMatcher": [],
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\scripts\\\\skaro-local.ps1",
        "status"
      ]
    },
    {
      "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "presentation": {
        "panel": "shared",
        "reveal": "always",
        "focus": false,
        "clear": true
      },
      "label": "Skaro: Config",
      "type": "shell",
      "problemMatcher": [],
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\scripts\\\\skaro-local.ps1",
        "config",
        "--show"
      ]
    }
  ]
