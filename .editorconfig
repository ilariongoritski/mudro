root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.go]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4

[*.{json,jsonl,yml,yaml,ts,tsx,js,jsx,css,scss,html}]
indent_style = space
indent_size = 2

[*.sql]
indent_style = space
indent_size = 2
