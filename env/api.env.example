# API service
API_ADDR=:8080
# NOTE: superuser DSN is allowed only for local dev hosts (localhost/127.0.0.1/db).
DSN=postgres://postgres:postgres@db:5432/gallery?sslmode=disable
JWT_SECRET=change-me-in-local-dev
CASINO_SERVICE_URL=http://127.0.0.1:8081

# HTTP rate limiter (0 = disabled)
API_RATE_LIMIT_RPS=20
API_RATE_LIMIT_BURST=40

# Distributed limiter via Redis (optional)
REDIS_RATE_LIMIT_ENABLED=false
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
