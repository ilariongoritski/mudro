# Agent service
# NOTE: superuser DSN is allowed only for local dev hosts (localhost/127.0.0.1/db).
DSN=postgres://postgres:postgres@db:5432/gallery?sslmode=disable
MUDRO_ROOT=/app

# Kafka placeholders (future async queue bridge)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=mudro-agent
KAFKA_TOPIC_TASKS=mudro.agent.tasks.v1
